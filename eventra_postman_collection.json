{
  "info": {
    "name": "Eventra Automated API Flow",
    "description": "Automated workflow testing the user registration, authentication, event creation, participation, and payment generation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Auth - Register User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set('testEmail', 'user_' + pm.variables.replaceIn('{{$randomInt}}') + '@test.com');",
              "pm.environment.set('testPassword', 'Pass123!@#');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Automated User\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "2. Auth - Login User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(jsonData.success) {",
              "    pm.environment.set('jwtToken', jsonData.data.token);",
              "}",
              "pm.test('Status code is 201 or 200', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "3. Auth - Get Me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{jwtToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "4. Event - Create Event",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(jsonData.success) {",
              "    pm.environment.set('eventId', jsonData.data.id);",
              "}",
              "pm.test('Status code is 201 or 200', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{jwtToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Automated Test Event\",\n  \"description\": \"This is a test event created by postman automation.\",\n  \"date\": \"2026-12-31T00:00:00Z\",\n  \"time\": \"10:00 AM\",\n  \"venue\": \"Virtual\",\n  \"type\": \"PUBLIC\",\n  \"fee\": 50\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/event",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "event"
          ]
        }
      }
    },
    {
      "name": "5. Event - Get All",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{jwtToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/event",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "event"
          ]
        }
      }
    },
    {
      "name": "6. Event - Get Single",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{jwtToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/event/{{eventId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "event",
            "{{eventId}}"
          ]
        }
      }
    },
    {
      "name": "7. Participation - Join Event",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{jwtToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"eventId\": \"{{eventId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/participation/join",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "participation",
            "join"
          ]
        }
      }
    },
    {
      "name": "8. Payment - Create Intent",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(jsonData.success && jsonData.data) {",
              "    pm.environment.set('clientSecret', jsonData.data.clientSecret);",
              "    pm.environment.set('transactionId', jsonData.data.transactionId);",
              "}",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{jwtToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"eventId\": \"{{eventId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/payment/create-intent",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "payment",
            "create-intent"
          ]
        }
      }
    },
    {
      "name": "9. Payment - Confirm",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{jwtToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transactionId\": \"{{transactionId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/payment/confirm",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "payment",
            "confirm"
          ]
        }
      }
    }
  ]
}
